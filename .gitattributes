# 自动检测文本文件并将换行符统一为 LF
* text=auto

# 明确声明需要统一转换的文本文件
*.md text
*.txt text
*.json text
*.yaml text
*.yml text
*.xml text
*.js text
*.ts text
*.tsx text
*.jsx text
*.py text
*.sh text
*.ps1 text
*.html text
*.css text
*.scss text
*.sql text

# 声明检出时始终使用 CRLF 换行符的文件
*.bat text eol=crlf
*.cmd text eol=crlf

# 标记真正的二进制文件，不应被修改
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
